# NEXUS OS Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# PHASE 1 - Command Center (Active)
# =============================================================================
APP_NAME="NEXUS OS"
APP_VERSION="1.0.0"
DEBUG=true
LOG_LEVEL=INFO

# Server Settings
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# =============================================================================
# PHASE 2 - Knowledge Cluster (Planned)
# =============================================================================
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio

# Embedding Model for RAG/Document Understanding
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# Vision Model (falls back to LMS model if empty)
LMS_VISION_MODEL=""

# Ollama fallback
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# DATABASE & STORAGE (Phase 2+)
# =============================================================================
DATA_DIR=./data
DATABASE_PATH=./data/nexus.db
CONVERSATIONS_DIR=./data/conversations
FILES_DIR=./data/files
MAX_FILE_SIZE_MB=50

# ChromaDB for vector embeddings
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_PREFIX=nexus

# Document Upload Configuration
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# RAG Chunking Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# =============================================================================
# REDIS / A2A MESSAGE BUS
# =============================================================================
REDIS_URL=redis://localhost:6379
A2A_SECRET_KEY=nexus-dev-secret-change-in-production
A2A_MESSAGE_TTL=3600

# =============================================================================
# PERSONALITIES
# =============================================================================
PERSONALITIES_DIR=./backend/personalities
ACTIVE_PERSONALITY=nexus_default

# =============================================================================
# AGENT LIMITS & TIMEOUTS
# =============================================================================
MAX_CONVERSATION_HISTORY=20
SUPERVISOR_TIMEOUT_SECONDS=60
MAX_CONCURRENT_AGENTS=10
