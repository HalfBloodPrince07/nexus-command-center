# NEXUS OS Environment Variables
# Copy this file to .env and set your local configuration.

# -- App Settings --
APP_NAME="NEXUS OS"
APP_VERSION="1.0.0"
DEBUG=True
LOG_LEVEL="INFO"

# -- Server Settings --
HOST="0.0.0.0"
PORT=8000
# Example for multiple origins: CORS_ORIGINS='["http://localhost:3000", "http://127.0.0.1:3000"]'
CORS_ORIGINS='["http://localhost:3000"]'

# -- AI Model Settings --
# LLM running in LM Studio (local inference only)
LM_STUDIO_BASE_URL="http://localhost:1234/v1"
LM_STUDIO_API_KEY="lm-studio"
SUPERVISOR_MODEL="local-model" # Set this to the model identifier used by your LLM provider
SUPERVISOR_TEMPERATURE=0.7
SUPERVISOR_MAX_TOKENS=2048
SUPERVISOR_CONTEXT_WINDOW=4096

# -- HF Transformers Embeddings (LOCAL MODEL - NOT LM Studio/Ollama) --
# Model downloaded directly from Hugging Face using huggingface_hub + torch
HF_EMBEDDING_MODEL_ID="nomic-ai/nomic-embed-text-v1.5"

# -- Data & Storage --
# DATA_DIR="./data" # Uncomment to override default
# DATABASE_PATH="./data/nexus.db" # Uncomment to override default
# CONVERSATIONS_DIR="./data/conversations" # Uncomment to override default

# -- A2A Message Bus --
REDIS_URL="redis://localhost:6379"
A2A_SECRET_KEY="nexus-dev-secret-change-in-production"
A2A_MESSAGE_TTL=3600

# -- Personality --
# PERSONALITIES_DIR="./personalities" # Uncomment to override default
ACTIVE_PERSONALITY="nexus_default"

# -- Agent & System Limits --
MAX_CONVERSATION_HISTORY=20
SUPERVISOR_TIMEOUT_SECONDS=60
MAX_CONCURRENT_AGENTS=10
